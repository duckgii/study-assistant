# Copy to .env for local/Oracle, or paste the same keys into Railway Variables.

# --- Railway ---
# AUTH_URL must be the Railway public URL, e.g. https://your-app.up.railway.app
# Mount a Volume at /data, then keep these paths:

DOMAIN=study.example.com

# Must match the public URL (https + DOMAIN or Railway domain).
AUTH_URL=https://study.example.com
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://YOUR_PUBLIC_URL/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google AI Studio / Gemini API key (free tier)
GEMINI_API_KEY=

# Persisted on Railway Volume mounted at /data
DATABASE_URL=file:/data/db/prod.db
UPLOADS_DIR=/data/uploads

# Contact form destination (defaults to shinyonggi@naver.com)
CONTACT_TO_EMAIL=shinyonggi@naver.com
# Optional: Resend API key for more reliable delivery. Without it, FormSubmit is used.
# RESEND_API_KEY=
# CONTACT_FROM_EMAIL=Study Assistant <onboarding@resend.dev>
